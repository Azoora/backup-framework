#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# abf  --  Backup Framework CLI
#
# Flat command structure:
#   abf backup   <service>     Create a backup
#   abf restore  <service>     Restore from backup
#   abf list     [service]     List available backups
#   abf config   check         Validate configuration
#
# Per spec coding standard:
set -Eeuo pipefail
# ---------------------------------------------------------------------------

ABF_ROOT="$(cd "$(dirname "$0")" && pwd)"
export ABF_ROOT

# ------------------------------------------------------------------
# Bootstrap
# ------------------------------------------------------------------
# shellcheck source=core/exit_codes.sh
source "${ABF_ROOT}/core/exit_codes.sh"
# shellcheck source=core/log.sh
source "${ABF_ROOT}/core/log.sh"
# shellcheck source=core/config.sh
source "${ABF_ROOT}/core/config.sh"
# shellcheck source=core/restic.sh
source "${ABF_ROOT}/core/restic.sh"
# shellcheck source=core/notify.sh
source "${ABF_ROOT}/core/notify.sh"
# shellcheck source=core/retention.sh
source "${ABF_ROOT}/core/retention.sh"
# shellcheck source=core/lock.sh
source "${ABF_ROOT}/core/lock.sh"
# shellcheck source=core/scheduler.sh
source "${ABF_ROOT}/core/scheduler.sh"
# shellcheck source=core/diagnostics.sh
source "${ABF_ROOT}/core/diagnostics.sh"
# shellcheck source=core/migrate.sh
source "${ABF_ROOT}/core/migrate.sh"
# shellcheck source=core/restore.sh
source "${ABF_ROOT}/core/restore.sh"
# shellcheck source=core/core.sh
source "${ABF_ROOT}/core/core.sh"

ABF_VERSION="$(cat "${ABF_ROOT}/VERSION" 2>/dev/null || echo "unknown")"

# ------------------------------------------------------------------
# Help text
# ------------------------------------------------------------------

_abf_show_help() {
    cat <<EOF
Usage: abf [options] <command> [args]

Commands:
  backup <service>         Create a backup of the specified service
  restore <service>        Restore the specified service [--dry-run] [--snapshot ID] [--yes]
  list [service]           List available restic snapshots
   config check             Validate configuration
   config migrate           Migrate configuration (upgrade defaults)
  doctor [--json]          Run comprehensive health diagnostics
  schedule install <svc>   Schedule recurring backups
                           [--frequency daily|weekly|monthly|<cron>]
                           [--at HH:MM] [--on-day DAY] [--force]
  schedule remove <svc>    Remove a scheduled backup
  schedule status <svc>    Show schedule status for a service
  schedule list            List all scheduled backups

Options:
  --config DIR           Use an alternative configuration directory
  --verbose, -v          Enable debug logging (includes restic output)
  --version              Show version information
  --help, -h             Show this help message

Examples:
  abf backup vaultwarden
  abf restore vaultwarden --dry-run
  abf restore vaultwarden --yes
  abf schedule install vaultwarden --frequency daily --at 02:00
  abf schedule remove vaultwarden
  abf schedule list
EOF
}

# ------------------------------------------------------------------
# Command: backup
# ------------------------------------------------------------------

_abf_cmd_backup() {
    local service_name="$1"
    local log_dir="${ABF_LOG_DIR:-}"

    abf_init_logging "$service_name" "backup" "$log_dir"
    abf_log_info "=== Backup Framework v${ABF_VERSION} ==="

    if ! abf_service_exists "$service_name"; then
        abf_log_error "Unknown service: ${service_name}"
        echo "Available services:" >&2
        abf_list_services >&2
        return "$ABF_EXIT_SERVICE_NOT_FOUND"
    fi

    abf_run_backup "$service_name"
}

# ------------------------------------------------------------------
# Command: restore
# ------------------------------------------------------------------

_abf_cmd_restore() {
    local service_name="$1"
    local snapshot="${2:-}"
    local dry_run="${3:-false}"
    local yes="${4:-false}"
    local log_dir="${ABF_LOG_DIR:-}"

    abf_init_logging "$service_name" "restore" "$log_dir"
    abf_log_info "=== Backup Framework v${ABF_VERSION} ==="

    if ! abf_service_exists "$service_name"; then
        abf_log_error "Unknown service: ${service_name}"
        echo "Available services:" >&2
        abf_list_services >&2
        return "$ABF_EXIT_SERVICE_NOT_FOUND"
    fi

    if [[ -z "$snapshot" ]] && [[ "$dry_run" != "true" ]]; then
        abf_load_service_config "$service_name"
        local repo
        repo=$(_abf_get_storage_repo) || {
            abf_log_error "No storage configured -- cannot determine latest snapshot"
            return "$ABF_EXIT_RESTORE_FAILED"
        }
        abf_restic_init "$repo"
        local latest
        latest=$(abf_restic_get_latest_snapshot "$service_name")
        if [[ -z "$latest" ]]; then
            abf_log_error "No snapshots found for ${service_name}"
            return "$ABF_EXIT_RESTORE_FAILED"
        fi
        snapshot="$latest"
        abf_log_info "Auto-selected latest snapshot: ${snapshot}"
    fi

    abf_run_restore "$service_name" "$snapshot" "$dry_run" "$yes"
}

# ------------------------------------------------------------------
# Command: list
# ------------------------------------------------------------------

_abf_cmd_list() {
    local service_name="${1:-}"

    if [[ -n "$service_name" ]] && ! abf_service_exists "$service_name"; then
        echo "Unknown service: ${service_name}" >&2
        echo "Available services:" >&2
        abf_list_services >&2
        return "$ABF_EXIT_SERVICE_NOT_FOUND"
    fi

    abf_list_snapshots "$service_name"
}

# ------------------------------------------------------------------
# Command: config
# ------------------------------------------------------------------

_abf_cmd_config_check() {
    echo "Validating configuration..."
    echo ""
    if abf_validate_config; then
        echo "Configuration check: PASS"
        return "$ABF_EXIT_OK"
    else
        echo "Configuration check: FAIL"
        return "$ABF_EXIT_CONFIG_ERROR"
    fi
}

# ------------------------------------------------------------------
# Main
# ------------------------------------------------------------------

_abf_main() {
    local config_dir=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --config)   config_dir="$2"; shift 2 ;;
            --verbose|-v) ABF_VERBOSE="true"; export ABF_VERBOSE; shift ;;
            --version)  echo "abf ${ABF_VERSION}"; exit 0 ;;
            --help|-h)  _abf_show_help; exit 0 ;;
            *)          break ;;
        esac
    done

    if [[ $# -eq 0 ]]; then
        _abf_show_help
        exit 1
    fi

    abf_load_config "$config_dir" || exit "$ABF_EXIT_CONFIG_ERROR"

    local command="$1"
    shift

    case "$command" in
        backup)
            if [[ $# -lt 1 ]]; then
                echo "Usage: abf backup <service>" >&2
                exit 1
            fi
            _abf_cmd_backup "$1"
            ;;
        restore)
            local snapshot=""
            local dry_run="false"
            local yes="false"
            local service_name=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --snapshot) snapshot="$2"; shift 2 ;;
            --dry-run)  dry_run="true"; shift ;;
            --yes|-y)   yes="true"; shift ;;
            -*)
                echo "Unknown option: $1" >&2
                exit 1
                ;;
            *)
                if [[ -z "$service_name" ]]; then
                    service_name="$1"
                fi
                shift
                ;;
        esac
    done
    if [[ -z "$service_name" ]]; then
        echo "Usage: abf restore <service> [--snapshot ID] [--dry-run] [--yes]" >&2
        echo "  --snapshot ID   Restic snapshot ID (default: latest)" >&2
        echo "  --dry-run       Simulate restore without modifying files" >&2
        echo "  --yes, -y       Skip interactive confirmation" >&2
        exit 1
    fi
            _abf_cmd_restore "$service_name" "$snapshot" "$dry_run" "$yes"
            ;;
        list)
            _abf_cmd_list "${1:-}"
            ;;
        config)
            case "${1:-}" in
                check|"")
                    _abf_cmd_config_check
                    ;;
                migrate)
                    shift
                    abf_config_migrate
                    ;;
                *)
                    echo "Usage: abf config {check|migrate}" >&2
                    exit 1
                    ;;
            esac
            ;;
        doctor)
            local json_mode="false"
            if [[ "${1:-}" == "--json" ]]; then
                json_mode="true"
            fi
            abf_doctor_run "$json_mode"
            ;;
        schedule)
            local subcommand="${1:-}"

            case "$subcommand" in
                install)
                    if [[ $# -lt 2 ]]; then
                        echo "Usage: abf schedule install <service> [options]" >&2
                        echo "  --frequency daily|weekly|monthly|<cron>" >&2
                        echo "  --at HH:MM" >&2
                        echo "  --on-day DAY (0=Sun for weekly, 1-31 for monthly)" >&2
                        echo "  --force" >&2
                        exit 1
                    fi
                    shift
                    local svc="$1"; shift
                    local freq="daily" time="03:00" day="0" force="false"
                    while [[ $# -gt 0 ]]; do
                        case "$1" in
                            --frequency) freq="$2"; shift 2 ;;
                            --at)        time="$2"; shift 2 ;;
                            --on-day)    day="$2";  shift 2 ;;
                            --force)     force="true"; shift ;;
                            *)           break ;;
                        esac
                    done
                    abf_schedule_install "$svc" "$freq" "$time" "$day" "$force"
                    ;;
                remove)
                    if [[ $# -lt 2 ]]; then
                        echo "Usage: abf schedule remove <service>" >&2
                        exit 1
                    fi
                    abf_schedule_remove "$2"
                    ;;
                status)
                    if [[ $# -lt 2 ]]; then
                        echo "Usage: abf schedule status <service>" >&2
                        exit 1
                    fi
                    abf_schedule_status "$2"
                    ;;
                list)
                    abf_schedule_list
                    ;;
                *)
                    echo "Usage: abf schedule install|remove|status|list" >&2
                    exit 1
                    ;;
            esac
            ;;
        *)
            echo "Unknown command: ${command}" >&2
            _abf_show_help
            exit 1
            ;;
    esac
}

_abf_main "$@"
